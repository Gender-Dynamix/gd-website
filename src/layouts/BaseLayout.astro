---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PrivacyModal from '../components/PrivacyModal.astro';
import TermsModal from '../components/TermsModal.astro';
import SafetyTutorialModal from '../components/SafetyTutorialModal.astro';
import BackToTopButton from '../components/BackToTopButton.astro';
import SafetyExitButton from '../components/SafetyExitButton.astro';
import PrivacyBanner from '../components/PrivacyBanner.astro';
import KeyboardHandler from '../components/KeyboardHandler.astro';
import FocusTrap from '../components/FocusTrap.astro';
import WaveDivider from '../components/WaveDivider.astro';

import '../styles/base.css';
import '../styles/navigation.css';
import '../styles/footer.css';
import '../styles/components.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
}

const {
  title,
  description = 'Professional Individual therapy, group support, advocacy, and peer support for transgender, non-binary and gender diverse people in Tauranga and the wider Bay of Plenty',
  ogTitle,
  ogDescription,
  ogImage = '/images/gd-logolong.webp',
  ogUrl,
} = Astro.props;

const resolvedOgImage = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" href="/images/favicon.ico" type="image/x-icon" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {ogTitle && <meta property="og:title" content={ogTitle} />}
    {
      ogDescription && (
        <meta property="og:description" content={ogDescription} />
      )
    }
    <meta property="og:image" content={resolvedOgImage} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>
  <body>
    <FocusTrap />
    <PrivacyModal />
    <TermsModal />
    <SafetyTutorialModal />
    <slot name="modals" />

    <Header />

    <main>
      <slot />
    </main>

    <WaveDivider fill="#20173a" direction="down" />
    <Footer />

    <slot name="after-footer" />

    <BackToTopButton />
    <SafetyExitButton />
    <PrivacyBanner />
    <KeyboardHandler />
  </body>
</html>
