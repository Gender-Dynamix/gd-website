<!-- Safety Exit Tutorial Modal -->
<div
  id="safetyTutorialModal"
  class="modal"
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
  aria-labelledby="safetyTutorialTitle"
>
  <div class="modal-overlay"></div>
  <div class="modal-container">
    <div class="modal-header">
      <h3 id="safetyTutorialTitle">Quick Exit Feature</h3>
      <button class="modal-close" aria-label="Close Modal"> &times; </button>
    </div>
    <div class="modal-body">
      <div class="safety-tutorial-icon">
        <i class="fas fa-door-open"></i>
      </div>

      <p class="safety-tutorial-intro">
        <strong>Your safety and privacy matter to us.</strong>
      </p>

      <p>
        We've included a Quick Exit feature to help you leave this website
        instantly if you need to. Here's how it works:
      </p>

      <div class="safety-tutorial-methods">
        <div class="safety-method">
          <div class="method-icon">
            <i class="fas fa-keyboard"></i>
          </div>
          <h4>Keyboard Shortcut</h4>
          <p>
            Press the <kbd>ESC</kbd> key
            <strong>three times quickly</strong> to immediately exit to a neutral
            website.
          </p>
        </div>

        <div class="safety-method">
          <div class="method-icon">
            <i class="fas fa-mouse-pointer"></i>
          </div>
          <h4>Exit Button</h4>
          <p>
            Click the red <strong>"EXIT"</strong> button in the bottom left corner
            of any page.
          </p>
        </div>
      </div>
      <div class="safety-tutorial-note">
        <i class="fas fa-info-circle"></i>
        <p>
          <strong>Note:</strong> The Quick Exit will clear your session data and redirect
          you to a neutral website. Your browser history may still show this site
          unless you use a private/incognito mode.
        </p>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-modal-primary" id="confirmSafetyTutorialBtn">
        Got it, thanks!
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const modal = document.getElementById('safetyTutorialModal');
    if (!modal) return;

    const closeBtn = modal.querySelector('.modal-close');
    const confirmBtn = document.getElementById('confirmSafetyTutorialBtn');
    var focusTrap = window.createFocusTrap(modal);

    function closeSafetyModal() {
      modal.classList.remove('active');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('no-scroll');
      focusTrap.deactivate();
    }

    function confirmSafetyTutorial() {
      localStorage.setItem('gdnz-safety-tutorial-seen', 'true');
      closeSafetyModal();
    }

    closeBtn.addEventListener('click', closeSafetyModal);
    confirmBtn.addEventListener('click', confirmSafetyTutorial);

    // Show tutorial on first visit after 2 seconds
    var hasSeenTutorial = localStorage.getItem('gdnz-safety-tutorial-seen');
    if (!hasSeenTutorial) {
      setTimeout(function () {
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('no-scroll');
        focusTrap.activate();
      }, 2000);
    }

    window.closeSafetyModal = closeSafetyModal;
  })();
</script>
