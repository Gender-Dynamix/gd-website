<!--Safe Exit Button-->
<a
  href="https://www.stuff.co.nz/"
  class="btn-safety-exit"
  id="quickExit"
  aria-label="Quick exit — leave this site immediately"
>
  <span class="exit-text">Exit</span>
  <span class="esc-text">ESC</span>
</a>

<script is:inline>
  (function () {
    var safetyBtn = document.getElementById('quickExit');
    if (!safetyBtn) return;

    safetyBtn.addEventListener('click', function () {
      sessionStorage.clear();
    });

    window.addEventListener('scroll', function () {
      if (window.scrollY > 300) {
        safetyBtn.classList.add('show');
      } else {
        safetyBtn.classList.remove('show');
      }
    });

    // Footer observer
    var footer = document.querySelector('.main-footer');
    if (footer) {
      var footerObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              safetyBtn.classList.add('at-footer');
            } else {
              safetyBtn.classList.remove('at-footer');
            }
          });
        },
        {
          root: null,
          threshold: 0,
          rootMargin: '0px 0px -20px 0px',
        },
      );
      footerObserver.observe(footer);
    }

    // Triple ESC safety exit
    var SafetyExit = {
      pressCount: 0,
      timeout: null,
      targetUrl: 'https://www.stuff.co.nz/',

      trigger: function () {
        sessionStorage.clear();
        window.location.replace(this.targetUrl);
      },

      handleKeydown: function (e) {
        this.pressCount++;
        clearTimeout(this.timeout);

        if (this.pressCount === 3) {
          e.preventDefault();
          this.trigger();
          return;
        }

        var self = this;
        this.timeout = setTimeout(function () {
          self.pressCount = 0;
        }, 1500);
      },
    };

    window.SafetyExit = SafetyExit;
  })();
</script>
