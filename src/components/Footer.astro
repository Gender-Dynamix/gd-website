---
const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
  <div class="footer-section contact-info">
    <p>Gender Dynamix of Aotearoa</p>
    <p>Building 55, Historic Village</p>
    <p>17th Avenue, Tauranga</p>
    <p>Phone: <a href="tel:075482972" rel="nofollow">07 548 2972</a></p>
    <p>
      <a
        href="#"
        class="email-link"
        data-user="referrals"
        data-domain="gdnz.org">Email Us</a
      >
    </p>
  </div>
  <div class="footer-section links-socials">
    <a
      href="https://www.instagram.com/genderdynamixnz/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Visit our Instagram page"><i class="fab fa-instagram"></i></a
    >
    <a
      href="https://www.facebook.com/genderdynamixnz/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Visit our Facebook page"><i class="fab fa-facebook-f"></i></a
    >
    <a
      href="#"
      class="email-link"
      data-user="referrals"
      data-domain="gdnz.org"
      aria-label="Email Us"><i class="fa-solid fa-envelope"></i></a
    >
  </div>
  <div class="footer-legal">
    <a href="#" class="js-terms-trigger">Terms & Conditions</a>
    |
    <a href="#" class="js-privacy-trigger">Privacy Policy</a>
    <p>&copy; Gender Dynamix of Aotearoa {currentYear}</p>
  </div>
</footer>

<script is:inline>
  (function () {
    // Footer legal links
    var termsLink = document.querySelector('.footer-legal .js-terms-trigger');
    if (termsLink) {
      termsLink.addEventListener('click', function (e) {
        e.preventDefault();
        if (window.openTermsModal) window.openTermsModal();
      });
    }

    var privacyLink = document.querySelector(
      '.footer-legal .js-privacy-trigger',
    );
    if (privacyLink) {
      privacyLink.addEventListener('click', function (e) {
        e.preventDefault();
        if (window.openPrivacyModal) window.openPrivacyModal();
      });
    }
  })();
</script>
