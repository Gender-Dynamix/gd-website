---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaveDivider from '../components/WaveDivider.astro';
import '../styles/donate.css';
---

<BaseLayout
  title="Donate & Support Our Work | Gender Dynamix Aotearoa"
  description="Support transgender and gender diverse people in the Bay of Plenty. Your donation to Gender Dynamix funds vital advocacy, individual support, and peer groups."
  ogTitle="Support Gender Dynamix Aotearoa | Local Community Funding"
  ogDescription="Help us continue providing life-changing support for the gender diverse community in Tauranga. Every contribution makes a difference."
>
  <section class="hero" tabindex="0">
    <div class="hero-bg-container">
      <img src="/images/hero-pattern-bg.webp" alt="" class="hero-bg-img" />
    </div>
    <div class="hero-content">
      <h1>Support Us</h1>
      <p>
        Every donation changes a life. Help us provide vital services to the
        transgender and gender diverse community.
      </p>
    </div>
    <div class="custom-shape-divider-top">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1440 320"
        preserveAspectRatio="none"
      >
        <path
          fill="#ad98c4"
          fill-opacity="0.99"
          d="M0,160L60,176C120,192,240,224,360,224C480,224,600,192,720,165.3C840,139,960,117,1080,117.3C1200,117,1320,139,1380,149.3L1440,160L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"
        ></path>
      </svg>
    </div>
  </section>

  <!--Impact Section-->
  <section class="impact-section">
    <div class="content-row image-left">
      <div class="content-image">
        <img src="/images/community.jpg" alt="" />
      </div>
      <div class="content-text" tabindex="1">
        <h2>Your Impact Matters</h2>
        <p>
          The support we provide makes a real difference in the lives of trans
          and nonbinary people in our community. Many face high levels of
          discrimination, poverty, homelessness, and mental health challenges.
        </p>
        <p>
          <strong
            >Your generous donation helps real people in our community thrive by
            being their authentic selves.</strong
          >
        </p>
      </div>
    </div>

    <!--Services Impact-->
    <div class="services-impact">
      <div class="service-impact-card">
        <div class="service-impact-icon">
          <i class="fa-solid fa-brain"></i>
        </div>
        <div class="service-support-header">
          <h3>Mental Health Support</h3>
        </div>
        <div class="service-support-desc">
          <p>
            Individual and group counseling for trans and gender diverse people.
          </p>
        </div>
      </div>

      <div class="service-impact-card">
        <div class="service-impact-icon">
          <i class="fa-solid fa-user-group"></i>
        </div>
        <div class="service-support-header">
          <h3>Peer Support</h3>
        </div>
        <div class="service-support-desc">
          <p>
            Individual or group Peer to peer support led by trained facilitators
            with lived experience.
          </p>
        </div>
      </div>

      <div class="service-impact-card">
        <div class="service-impact-icon">
          <i class="fa-solid fa-graduation-cap"></i>
        </div>
        <div class="service-support-header">
          <h3>Education & Workshops</h3>
        </div>
        <div class="service-support-desc">
          <p>
            Community education and training for businesses, schools, and
            healthcare providers
          </p>
        </div>
      </div>

      <div class="service-impact-card">
        <div class="service-impact-icon">
          <i class="fa-solid fa-hand-holding-heart"></i>
        </div>
        <div class="service-support-header">
          <h3>Whānau Support</h3>
        </div>
        <div class="service-support-desc">
          <p>Resources and guidance for families and support networks</p>
        </div>
      </div>
    </div>
  </section>

  <section class="donation-cta-section">
    <div class="content-row image-right">
      <div class="content-text donation-box">
        <h2>Support Us Today</h2>
        <p>
          We use Givealittle, New Zealand's trusted fundraising platform, to
          securely process donations. Your contribution goes directly towards
          supporting our vital community services
        </p>
        <a
          href="https://givealittle.co.nz/your-campaign-link"
          class="givealittle-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fas fa-heart"></i>
          Donate via Givealittle
        </a>
        <div class="donation-features">
          <div class="feature">
            <i class="fa-solid fa-circle-check"></i>
            <span>Secure and trusted platform</span>
          </div>
          <div class="feature">
            <i class="fa-solid fa-circle-check"></i>
            <span>Tax receipts available</span>
          </div>
          <div class="feature">
            <i class="fa-solid fa-circle-check"></i>
            <span>One-time or regular donations</span>
          </div>
        </div>
      </div>
      <div class="content-image">
        <img
          src="/images/252_heart_trans_flag.jpg"
          alt="Transgender pride heart"
        />
      </div>
    </div>
  </section>

  <section class="alternative-giving">
    <div class="content-row image-left">
      <div class="content-image">
        <img
          src="/images/charity.png"
          alt="Drawing of people placing their hands to form a heart shape"
        />
      </div>
      <div class="content-text">
        <h2>Other ways to give</h2>
        <p>
          Prefer to to donate via direct bank transfer? Use the details below:
        </p>
        <div class="bank-details-card">
          <div class="bank-detail">
            <strong>Account Name:</strong>
            <span>Gender Dynamix</span>
          </div>
          <div class="bank-detail">
            <strong>Account Number:</strong>
            <span>02-0466-0357423-00</span>
          </div>
          <div class="bank-detail">
            <strong>Reference:</strong>
            <span>Your Name / Donation</span>
          </div>
        </div>

        <div class="alternative-options">
          <div class="alt-option-icon">
            <i class="fas fa-money-bill-wave"></i>
          </div>
          <h3>Cash or Cheque Donations</h3>
          <p>
            Can be dropped off at our office during business hours or mailed to:
          </p>
          <div class="office-address">
            <strong>Gender Dynamix of Aotearoa</strong><br />
            Building 55, Historic Village<br />
            17th Avenue, Tauranga
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="sponsors-section">
    <div class="sponsors-container">
      <h2>Special Thanks to Our Sponsors</h2>
      <p class="sponsors-intro">
        We're grateful for the generous support of these organizations who share
        our vision of an inclusive Aotearoa
      </p>

      <div class="sponsors-grid">
        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/acorn_foundation_logo.png"
            alt="Acorn Foundation Logo"
          />
        </div>

        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/baytrust_logo.png"
            alt="Baytrust Logo"
          />
        </div>

        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/lion-foundation_logo.png"
            alt="Lion Foundation Logo"
          />
        </div>

        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/lottery-grants-board-logo.png"
            alt="Lottery Grants Board Logo"
          />
        </div>

        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/tauranga_west_bay_community_event_fund_logo.png"
            alt="Tauranga West Bay Community Event Fund Logo"
          />
        </div>

        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/tect_logo.png"
            alt="TECT Logo"
          />
        </div>

        <div class="sponsor-card">
          <img
            src="/images/organisation-logos/sponsors/upshot_logo.jpg"
            alt="Upshot Logo"
          />
        </div>
      </div>
      <div class="become-sponsor">
        <h3>Interested in supporting our work?</h3>
        <p>
          We welcome partnerships with organisations who share our values.
          <a href="/contact">Get in touch</a> to learn more about sponsorship opportunities
        </p>
      </div>
    </div>
  </section>

  <WaveDivider fill="#ad98c4" direction="up" />
</BaseLayout>
