---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaveDivider from '../components/WaveDivider.astro';
import '../styles/contact.css';
---

<BaseLayout
  title="Contact Us & Referrals | Gender Dynamix Aotearoa"
  description="Get in touch with our Tauranga Office. Use our secure referral form for individual therapy, general inquiries or professional training"
  ogTitle="Contact Us | Make a Referral | Gender Dynamix Aotearoa"
  ogDescription="Access our secure referral forms and contact information for gender-diverse support services in the Bay of Plenty."
>
  <section class="hero">
    <div class="hero-bg-container">
      <img src="/images/hero-pattern-bg.webp" alt="" class="hero-bg-img" />
    </div>
    <div class="hero-content">
      <h1>Get in touch with us</h1>
      <p>
        We're here to listen and support you. Reach out for services,
        referrals, or any questions about our work with the transgender and
        gender diverse community.
      </p>
    </div>
    <div class="custom-shape-divider-top">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1440 320"
        preserveAspectRatio="none"
      >
        <path
          fill="#ad98c4"
          fill-opacity="1"
          d="M0,160L60,176C120,192,240,224,360,224C480,224,600,192,720,165.3C840,139,960,117,1080,117.3C1200,117,1320,139,1380,149.3L1440,160L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"
        ></path>
      </svg>
    </div>
  </section>

  <section class="contact-nav">
    <div class="contact-nav-container">
      <h2>How can we help you?</h2>
      <div class="contact-nav-grid">
        <a href="#general-contact" class="contact-nav-btn">
          <div class="contact-icon">
            <i class="fas fa-envelope"></i>
          </div>
          <h3>General Inquiry</h3>
          <p>Questions about our services</p>
        </a>

        <a href="#referrals" class="contact-nav-btn">
          <div class="contact-icon">
            <i class="fas fa-user-plus"></i>
          </div>
          <h3>Referrals</h3>
          <p>Access our support services</p>
        </a>

        <a href="#contact-info" class="contact-nav-btn">
          <div class="contact-icon">
            <i class="fas fa-map-marker-alt"></i>
          </div>
          <h3>Visit Us</h3>
          <p>Location, office hours and contact info</p>
        </a>
      </div>
    </div>
  </section>

  <WaveDivider fill="#ad98c4" direction="up" />

  <section class="form-card-section" id="general-contact">
    <div class="form-card-container">
      <div class="form-card-header js-accordion-header">
        <div class="form-title-group">
          <div class="form-icon">
            <i class="fas fa-envelope"></i>
          </div>
          <h2>General Inquiry</h2>
        </div>
        <button
          class="form-collapse-btn accordion-toggle"
          aria-label="Toggle form"
          aria-expanded="true"
        >
          <i class="fas fa-arrow-up"></i>
        </button>
      </div>

      <div class="form-content">
        <p class="form-description">
          Have a question about our services or want to learn more about our
          work? Send us a message and we'll get back to you as soon as
          possible.
        </p>

        <form action="" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="gi-first-name">First Name:*</label>
              <input
                type="text"
                id="gi-first-name"
                name="first-name"
                required
              />
            </div>
            <div class="form-group">
              <label for="gi-last-name">Last Name:*</label>
              <input
                type="text"
                id="gi-last-name"
                name="last-name"
                required
              />
            </div>
          </div>

          <div class="form-group">
            <label for="gi-email">Email:*</label>
            <input type="email" id="gi-email" name="email" required />
          </div>

          <div class="form-group">
            <label for="subject">Subject:*</label>
            <select id="subject" name="subject" required>
              <option value="">Select a topic...</option>
              <option value="general">General Question</option>
              <option value="training">Professional Training</option>
              <option value="events">Events & Groups</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message:*</label>
            <textarea
              id="message"
              name="message"
              placeholder="How can we help you today?"
              required
            ></textarea>
          </div>

          <button type="submit" class="submit-btn">Send Message</button>
          <p class="privacy-notice">
            &#128274; Your message is sent via a secure connection
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Divider between forms -->
  <div class="logo-divider">
    <div class="divider-line"></div>
    <div class="divider-logo">
      <img src="/images/favicon.ico" alt="Gender Dynamix" />
    </div>
    <div class="divider-line"></div>
  </div>

  <!-- Referral Form Section -->
  <section class="form-card-section" id="referrals">
    <div class="form-card-container">
      <div class="form-card-header js-accordion-header">
        <div class="form-title-group">
          <div class="form-icon">
            <i class="fas fa-user-plus"></i>
          </div>
          <h2>Referral Form</h2>
        </div>
        <button
          class="form-collapse-btn accordion-toggle"
          aria-label="Toggle form"
          aria-expanded="true"
        >
          <i class="fas fa-arrow-up"></i>
        </button>
      </div>

      <div class="form-content service-content">
        <p class="form-description">
          Complete this form to refer yourself or someone else to our
          services. All information is kept confidential.
        </p>

        <div class="form-info-box">
          <h3>What to Expect</h3>
          <ul>
            <li>We'll review your referral within 2 business days</li>
            <li>A team member will contact you to discuss next steps</li>
            <li>All information is confidential and secure</li>
          </ul>
        </div>

        <h3>Referral Information</h3>
        <!-- TODO: Replace this with Finger-Ink Form Embed -->
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <div class="form-group">
            <label for="referral-type">Referral Type:*</label>
            <select id="referral-type" name="referral-type" required>
              <option value="">Select...</option>
              <option value="self">Self Referral</option>
              <option value="other">Referring Someone Else</option>
            </select>
          </div>

          <h4>Legal Full Name</h4>
          <div class="form-row">
            <div class="form-group">
              <label for="first-name">First Name:*</label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                required
              />
            </div>
            <div class="form-group">
              <label for="last-name">Last Name:*</label>
              <input type="text" id="last-name" name="last-name" required />
            </div>
          </div>

          <div class="form-group">
            <label for="preferred-name">Preferred Name:*</label>
            <input
              type="text"
              id="preferred-name"
              name="preferred-name"
              required
            />
          </div>

          <div class="form-group">
            <label for="referral-email">Email:*</label>
            <input type="email" id="referral-email" name="email" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone Number:*</label>
            <input type="tel" id="phone" name="phone" required />
          </div>

          <div class="form-group">
            <label for="address">Address:*</label>
            <input type="text" id="address" name="address" required />
          </div>

          <div class="form-group">
            <label for="city">City/Town:*</label>
            <input type="text" id="city" name="city" required />
          </div>

          <div class="form-group">
            <label for="suburb">Suburb:*</label>
            <input type="text" id="suburb" name="suburb" required />
          </div>

          <div class="form-group">
            <label for="area-code">Area Code:*</label>
            <input type="text" id="area-code" name="area-code" required />
          </div>

          <div class="form-group">
            <label for="referral-source">Referral Source:*</label>
            <input
              type="text"
              id="referral-source"
              name="referral-source"
              required
            />
          </div>

          <div class="form-group">
            <label for="NHI">NHI:*</label>
            <input type="text" id="NHI" name="NHI" />
          </div>

          <div class="form-group">
            <label for="out-status">Out Status:</label>
            <textarea
              id="out-status"
              name="out-status"
              placeholder="Tell us a bit about your 'out' status..."
            ></textarea>
          </div>

          <div class="form-group">
            <label>Services Interested In:*</label>
            <div class="checkbox-group">
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="mental-health"
                  name="services"
                  value="Mental Health Support"
                />
                <label for="mental-health">Mental Health Support</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="gender-exploration"
                  name="services"
                  value="Gender Exploration"
                />
                <label for="gender-exploration">Gender Exploration</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="peer-support"
                  name="services"
                  value="Peer Support"
                />
                <label for="peer-support">Peer Support</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="group-therapy"
                  name="services"
                  value="Group Therapy"
                />
                <label for="group-therapy">Group Therapy</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="whanau-support"
                  name="services"
                  value="Whānau Support"
                />
                <label for="whanau-support">Wh&#257;nau Support</label>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="additional-info">Additional Information:</label>
            <textarea
              id="additional-info"
              name="additional-info"
              placeholder="Tell us a bit about what support you're looking for..."
            ></textarea>
          </div>

          <button type="submit" class="submit-btn">Submit Referral</button>
          <p class="privacy-notice">
            &#128274; All information is encrypted and confidential
          </p>
        </form>
      </div>
    </div>
  </section>

  <div class="logo-divider">
    <div class="divider-line"></div>
    <div class="divider-logo">
      <img src="/images/favicon.ico" alt="Gender Dynamix" />
    </div>
    <div class="divider-line"></div>
  </div>

  <section class="contact-info" id="contact-info">
    <div class="contact-info-container">
      <div class="info-card">
        <h3>Contact Info</h3>
        <div class="info-content">
          <p class="contact-item">
            <i class="fas fa-map-marker-alt"></i>
            <span>
              <strong>Gender Dynamix of Aotearoa</strong><br />
              Building 55, Historic Village <br />
              17th, Avenue, Tauranga
            </span>
          </p>

          <p class="contact-item">
            <i class="fas fa-phone"></i>
            <a href="tel:075482972">07 548 2972</a>
          </p>

          <p class="contact-item">
            <i class="fas fa-envelope"></i>
            <a
              href="#"
              class="email-link"
              data-user="referrals"
              data-domain="gdnz.org"
              >Email Us</a
            >
          </p>

          <div class="social-icons-contact">
            <a
              href="https://www.instagram.com/genderdynamixnz/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <i class="fab fa-instagram"></i>
            </a>
            <a
              href="https://www.facebook.com/genderdynamixnz/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              ><i class="fab fa-facebook-f"></i
            ></a>
            <a href="mailto:referrals@gdnz.org" aria-label="Email">
              <i class="fas fa-envelope"></i>
            </a>
          </div>
        </div>
      </div>

      <div class="info-card">
        <h3>Office Hours</h3>
        <div class="info-content" tabindex="0">
          <p><strong>08:00-16:00 Mon-Fri</strong></p>
          <p>Closed: Saturday-Sunday</p>
          <p class="hours-note">
            We're closed on all national and public holidays. For urgent
            matters outside our hours, please email and we'll respond as
            soon as possible.
          </p>
        </div>
      </div>

      <div class="location-card">
        <div class="location-header">
          <div class="location-icon">
            <i class="fas fa-map-marker-alt"></i>
          </div>
          <h3>Location</h3>
        </div>
        <div class="map-container">
          <div class="map-embed">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3156.6481250046245!2d176.14620917730463!3d-37.70446207200315!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6d6dda4a159ecd97%3A0xa548d89a6ea2c131!2sThe%20Historic%20Village!5e0!3m2!1sen!2snz!4v1770680270680!5m2!1sen!2snz"
              width="600"
              height="450"
              style="border: 0"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <div class="detailed-map-card">
          <h4>Finding building 55</h4>
          <p>
            We're located in Building 55 within the Historic Village. Use
            this map to find us once you arrive:
          </p>
          <img
            src="/images/map.jpg"
            alt="Map displaying location of Building 55 within the historic village"
          />
          <div class="map-note">
            <p>
              <i class="fas fa-parking"></i> <strong>Parking:</strong> Free
              parking available on Seventeenth Avenue.
            </p>
            <p>
              <i class="fas fa-walking"></i> <strong>Access:</strong> Enter
              via pedestrian walkway near main entrance.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  function toggleAccordion(header) {
    var content = header.nextElementSibling;
    var icon = header.querySelector(".accordion-toggle i");
    content.classList.toggle("collapsed");
    if (content.classList.contains("collapsed")) {
      icon.classList.replace("fa-arrow-up", "fa-arrow-down");
      header
        .querySelector(".accordion-toggle")
        .setAttribute("aria-expanded", "false");
    } else {
      icon.classList.replace("fa-arrow-down", "fa-arrow-up");
      header
        .querySelector(".accordion-toggle")
        .setAttribute("aria-expanded", "true");
    }
  }

  var accordionHeaders = document.querySelectorAll(".js-accordion-header");
  accordionHeaders.forEach(function (header) {
    header.addEventListener("click", function () {
      toggleAccordion(header);
    });
    header.style.cursor = "pointer";
  });
})();
</script>
