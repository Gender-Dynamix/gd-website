---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaveDivider from '../components/WaveDivider.astro';
import '../styles/services.css';
---

<BaseLayout
  title="Gender Dynamix Aotearoa"
  description="Explore our gender-diverse services in Tauranga: individual advocacy, peer support groups, and professional diversity training for organisations and schools."
  ogTitle="Gender-Diverse Support Services | Gender Dynamix Aotearoa"
  ogDescription="From individual advocacy to community groups—see how we support the transgender and gender-diverse community."
>
  <section class="hero">
    <div class="hero-bg-container">
      <img src="/images/hero-pattern-bg.webp" alt="" class="hero-bg-img" />
    </div>
    <div class="hero-content">
      <h1>Our Services</h1>
      <p>
        At Gender Dynamix we offer a range of comprehensive services and
        resources tailored to the unique needs of our trans and non-binary and
        gender diverse wh&#257;nau.<br />
        We are committed to fostering a welcoming community where you can explore,
        grow, and connect on your journey towards self-discovery and empowerment.
      </p>
    </div>
    <div class="custom-shape-divider-top">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1440 320"
        preserveAspectRatio="none"
      >
        <path
          fill="#ad98c4"
          fill-opacity="1"
          d="M0,160L60,176C120,192,240,224,360,224C480,224,600,192,720,165.3C840,139,960,117,1080,117.3C1200,117,1320,139,1380,149.3L1440,160L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"
        ></path>
      </svg>
    </div>
  </section>

  <section class="quick-nav-services">
    <div class="quick-nav-container">
      <h2>Jump to Section</h2>
      <div class="quick-nav-grid">
        <a href="#individual-support" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/icons-01.webp" alt="Individual Support" />
          </div>
          <h3>Individual Support</h3>
        </a>
        <a href="#peer-support" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/icons-02.webp" alt="Peer Support" />
          </div>
          <h3>Peer Support</h3>
        </a>
        <a href="#group-support" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/icons-03.webp" alt="Group Support" />
          </div>
          <h3>Group Support</h3>
        </a>
        <a href="#training" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/work_icon.svg" alt="Training" />
          </div>
          <h3>Training</h3>
        </a>
      </div>
    </div>
  </section>

  <WaveDivider fill="#ad98c4" direction="up" />

  <!--Individual Support-->
  <section class="service-detail" id="individual-support">
    <div class="service-detail-container">
      <div class="service-header js-accordion-header">
        <div class="service-title-group">
          <div class="service-icon-small">
            <img src="/images/icons-01.webp" alt="Individual Support Icon" />
          </div>
          <h2>Individual Support Services</h2>
        </div>
        <button
          class="accordion-toggle"
          aria-label="Toggle section"
          aria-expanded="true"
        >
          <i class="fas fa-arrow-up"></i>
        </button>
      </div>

      <div class="service-content">
        <p class="service-description">
          Lorem ipsum dolor sit amet consectetur adipiscing elit. Dolor amet
          consectetur adipiscing elit quisque faucibus.
        </p>

        <div class="service-categories">
          <div class="category-card">
            <h3>Mental Health Care:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>Transition Support:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>Ongoing Care:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>IPL Laser Hair Removal:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!--Peer Support-->
  <section class="service-detail" id="peer-support">
    <div class="service-detail-container">
      <div class="service-header js-accordion-header">
        <div class="service-title-group">
          <div class="service-icon-small">
            <img src="/images/icons-02.webp" alt="Peer Support Icon" />
          </div>
          <h2>Peer Support Services</h2>
        </div>
        <button
          class="accordion-toggle"
          aria-label="Toggle section"
          aria-expanded="true"
        >
          <i class="fas fa-arrow-up"></i>
        </button>
      </div>

      <div class="service-content">
        <p class="service-description">
          Lorem ipsum dolor sit amet consectetur adipiscing elit. Dolor amet
          consectetur adipiscing elit quisque faucibus.
        </p>

        <div class="service-categories">
          <div class="category-card">
            <h3>Peer to Peer:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>Transition Support:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>Ongoing Care:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!--Group Support Services-->
  <section class="service-detail" id="group-support">
    <div class="service-detail-container">
      <div class="service-header js-accordion-header">
        <div class="service-title-group">
          <div class="service-icon-small">
            <img src="/images/icons-03.webp" alt="Group Support Icon" />
          </div>
          <h2>Group Support Services</h2>
        </div>
        <button
          class="accordion-toggle"
          aria-label="Toggle section"
          aria-expanded="true"
        >
          <i class="fas fa-arrow-up"></i>
        </button>
      </div>

      <div class="service-content">
        <p class="service-description">
          Lorem ipsum dolor sit amet consectetur adipiscing elit. Dolor amet
          consectetur adipiscing elit quisque faucibus.
        </p>

        <div class="service-categories">
          <div class="category-card">
            <h3>Mental Health Care:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>Transition Support:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>

          <div class="category-card">
            <h3>Ongoing Care:</h3>
            <ul>
              <li>Item 1</li>
              <li>Item 2</li>
              <li>Item 3</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="cta-banner-container">
      <h2>Ready To Connect?</h2>
      <p>Reach out today to learn more about our services or book a referral</p>
      <a href="/contact" class="cta-button">Get In Touch</a>
    </div>
  </section>

  <!-- Training Form Section -->
  <section class="form-card-section" id="training">
    <div class="form-card-container">
      <div class="form-card-header js-accordion-header">
        <div class="form-title-group">
          <div class="form-icon">
            <img src="/images/work_icon.svg" alt="Training Icon" />
          </div>
          <h2>Training</h2>
        </div>
        <button
          class="form-collapse-btn accordion-toggle"
          aria-label="Toggle form"
        >
          <i class="fas fa-arrow-up"></i>
        </button>
      </div>

      <div class="form-content service-content">
        <p class="form-description">
          Lorem ipsum dolor sit amet consectetur adipiscing elit. Dolor sit amet
          consectetur adipiscing elit quisque faucibus.
        </p>

        <div class="form-info-box">
          <h3>What We Offer</h3>
          <ul>
            <li>Item 1</li>
            <li>Item 2</li>
            <li>Item 3</li>
          </ul>
        </div>

        <h3>Interested in Training?</h3>
        <p class="form-subtitle">
          Book a Training Session<br />Organisations/Schools
        </p>
        <!-- TODO: Replace this with Finger-Ink Form -->
        <form data-form-type="training">
          <input type="hidden" name="form-type" value="training" />
          <div class="visually-hidden" aria-hidden="true">
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
            />
          </div>
          <div class="form-group">
            <label for="contact-name">Contact Name:*</label>
            <input type="text" id="contact-name" name="contact-name" required />
          </div>

          <div class="form-group">
            <label for="email">Email:*</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="form-group">
            <label for="contact-phone">Contact Phone:*</label>
            <input
              type="tel"
              id="contact-phone"
              name="contact-phone"
              required
            />
          </div>

          <div class="form-group">
            <label>What would you like covered in training?*</label>
            <div class="checkbox-group">
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item1"
                  name="training-topics"
                  value="Item 1"
                />
                <label for="item1">Item 1</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item2"
                  name="training-topics"
                  value="Item 2"
                />
                <label for="item2">Item 2</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item3"
                  name="training-topics"
                  value="Item 3"
                />
                <label for="item3">Item 3</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item4"
                  name="training-topics"
                  value="Item 4"
                />
                <label for="item4">Item 4</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item5"
                  name="training-topics"
                  value="Item 5"
                />
                <label for="item5">Item 5</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item6"
                  name="training-topics"
                  value="Item 6"
                />
                <label for="item6">Item 6</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item7"
                  name="training-topics"
                  value="Item 7"
                />
                <label for="item7">Item 7</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item8"
                  name="training-topics"
                  value="Item 8"
                />
                <label for="item8">Item 8</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item9"
                  name="training-topics"
                  value="Item 9"
                />
                <label for="item9">Item 9</label>
              </div>
              <div class="checkbox-option">
                <input
                  type="checkbox"
                  id="item10"
                  name="training-topics"
                  value="Item 10"
                />
                <label for="item10">Item 10</label>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="training-hours"
              >How long should training take place?*</label
            >
            <select id="training-hours" name="training-hours" required>
              <option value="30-min">30 Minutes</option>
              <option value="1-hour">1 Hour</option>
              <option value="2-hours">2 Hours</option>
              <option value="3-hours">3 Hours</option>
              <option value="half-day">Half Day</option>
              <option value="full-day">Full Day</option>
            </select>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="start-date">Start date *</label>
              <input
                type="text"
                id="start-date"
                name="start-date"
                placeholder="DD/MM/YYYY"
                required
              />
            </div>

            <div class="form-group">
              <label for="end-date">End date *</label>
              <input
                type="text"
                id="end-date"
                name="end-date"
                placeholder="DD/MM/YYYY"
                required
              />
            </div>
          </div>

          <div class="form-group">
            <label for="additional-notes">Additional Notes:</label>
            <textarea id="additional-notes" name="additional-notes"></textarea>
          </div>

          <div
            class="cf-turnstile"
            data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}
          >
          </div>
          <div class="form-feedback" aria-live="polite"></div>
          <button type="submit" class="submit-btn">Submit</button>
          <p class="privacy-notice">
            &#128274; All information is encrypted and confidential
          </p>
        </form>
      </div>
    </div>
  </section>
  <script src="../scripts/form-handler.ts"></script>
</BaseLayout>

<script is:inline>
  (function () {
    function toggleAccordion(header) {
      var content = header.nextElementSibling;
      var icon = header.querySelector('.accordion-toggle i');
      content.classList.toggle('collapsed');
      if (content.classList.contains('collapsed')) {
        icon.classList.replace('fa-arrow-up', 'fa-arrow-down');
        header
          .querySelector('.accordion-toggle')
          .setAttribute('aria-expanded', 'false');
      } else {
        icon.classList.replace('fa-arrow-down', 'fa-arrow-up');
        header
          .querySelector('.accordion-toggle')
          .setAttribute('aria-expanded', 'true');
      }
    }

    var accordionHeaders = document.querySelectorAll('.js-accordion-header');
    accordionHeaders.forEach(function (header) {
      header.addEventListener('click', function () {
        toggleAccordion(header);
      });
      header.style.cursor = 'pointer';
    });
  })();
</script>
