---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgeVerificationModal from '../components/AgeVerificationModal.astro';
import WaveDivider from '../components/WaveDivider.astro';
import '../styles/resources.css';
---

<BaseLayout
  title="Community Resources | Gender Affirming Gear & Info | Gender Dynamix"
  description="Access curated resources for the gender-diverse community in Aotearoa. Find NZ organisations, gender-affirming gear, and educational video content."
  ogTitle="NZ Gender Diverse Resource Directory | Gender Dynamix"
  ogDescription="A comprehensive guide to gender-affirming gear, local organisations, and educational tools for our community."
>
  <AgeVerificationModal slot="modals" />

  <section class="hero">
    <div class="hero-bg-container">
      <img src="/images/hero-pattern-bg.webp" alt="" class="hero-bg-img" />
    </div>

    <div class="hero-content">
      <h1>Resources</h1>
      <p>
        Your guide to essential support and resources. Connect with transgender
        and gender diverse organisations throughout Aotearoa, explore trusted
        suppliers of gender affirming gear, and discover educational videos to
        support your journey of self-discovery and empowerment.
      </p>
    </div>
    <div class="custom-shape-divider-top">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1440 320"
        preserveAspectRatio="none"
      >
        <path
          fill="#ad98c4"
          fill-opacity="1"
          d="M0,160L60,176C120,192,240,224,360,224C480,224,600,192,720,165.3C840,139,960,117,1080,117.3C1200,117,1320,139,1380,149.3L1440,160L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"
        ></path>
      </svg>
    </div>
  </section>

  <section class="quick-nav-services">
    <div class="quick-nav-container">
      <h2>Jump to Section</h2>
      <div class="quick-nav-grid">
        <a href="#kiwi-organisations" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/kiwi.svg" alt="Kiwi Organisations" />
          </div>
          <h3>Kiwi Organisations</h3>
        </a>
        <a href="#gender-affirming-gear" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/icons-01.webp" alt="Gender Affirming Gear" />
          </div>
          <h3>Gender Affirming Gear</h3>
        </a>
        <a href="#video-resources" class="quick-nav-btn">
          <div class="nav-icon">
            <img src="/images/icons-03.webp" alt="Video resources" />
          </div>
          <h3>Video Resources</h3>
        </a>
      </div>
    </div>
  </section>

  <WaveDivider fill="#ad98c4" direction="up" />

  <section class="kiwi-organisations" id="kiwi-organisations">
    <div class="section-heading">
      <h2>Kiwi Organisations</h2>
      <p>
        Connect with transgender and gender diverse organizations across
        Aotearoa New Zealand
      </p>
    </div>

    <div class="kiwi-cards-container">
      <!-- Card 1 -->
      <div class="kiwi-card">
        <div class="kiwi-img">
          <img
            src="/images/organisation-logos/outlineaotearoa.jpg"
            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category">Mental Health & Support Organisation</span
          >
          <h3>Outline Aotearoa</h3>
          <p>
            Nationwide rainbow support, counselling, and trans and nonbinary
            peer support service.
          </p>
          <a href="https://outline.org.nz/" class="kiwi-link">Visit Website!</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="kiwi-card">
        <div class="kiwi-img logo-light-bg">
          <img
            src="/images/organisation-logos/mhf.svg"
            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category">Mental Health & Support Organisation</span
          >
          <h3>Mental Health Foundation of New Zealand</h3>
          <p>Resources on mental health and wellbeing.</p>
          <a href="https://mentalhealth.org.nz/" class="kiwi-link"
            >Visit Website!</a
          >
        </div>
      </div>

      <!-- Card 3 -->
      <div class="kiwi-card">
        <div class="kiwi-img">
          <img
            src="/images/organisation-logos/insideout-logo-transparent-550.png"
            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category">Mental Health & Support Organisation</span
          >
          <h3>InsideOUT</h3>
          <p>
            InsideOUT K&#333;aro is a national charity working to make Aotearoa
            safer for all rainbow and takat&#257;pui people. We provide
            resources, workshops, consulting, advocacy and support for anything
            concerning rainbow (LGBTQIA+) communities.
          </p>
          <a href="https://insideout.org.nz/" class="kiwi-link"
            >Visit Website!</a
          >
        </div>
      </div>

      <!-- Card 4 -->
      <div class="kiwi-card">
        <div class="kiwi-img">
          <img
            src="/images/organisation-logos/tki-logo.jpg"
            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category"
            >Gender Diverse Education Organisation</span
          >
          <h3>Inclusive Education</h3>
          <p>
            How New Zealand schools support trans and other rainbow students.
          </p>
          <a href="https://inclusive.tki.org.nz/" class="kiwi-link"
            >Visit Website!</a
          >
        </div>
      </div>

      <!-- Card 5 -->
      <div class="kiwi-card">
        <div class="kiwi-img">
          <img
            src="/images/organisation-logos/patha-logo.png"
