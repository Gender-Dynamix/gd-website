            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category"
            >Gender Diverse Informational Organisation</span
          >
          <h3>Gender Minorities Aotearoa</h3>
          <p>
            A peer-led organisation that provides a national service and
            information database.
          </p>
          <a href="https://genderminorities.com/" class="kiwi-link"
            >Visit Website!</a
          >
        </div>
      </div>

      <!-- Card 10 -->
      <div class="kiwi-card">
        <div class="kiwi-img logo-light-bg">
          <img
            src="/images/organisation-logos/healthnz-logo-v2.svg"
            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category">Gender Diverse Health Organisation</span>
          <h3>Health New Zealand</h3>
          <p>Gender affirming care and support services.</p>
          <a
            href="https://info.health.nz/conditions-treatments/mental-health/gender-affirming-care/"
            class="kiwi-link">Visit Website!</a
          >
        </div>
      </div>

      <!-- Card 11 -->
      <div class="kiwi-card">
        <div class="kiwi-img">
          <img
            src="/images/organisation-logos/wpath_logo_words-1.png"
            alt="WPATH logo"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category">
            Worldwide Gender Diverse Health Organisation</span
          >
          <h3>WPATH</h3>
          <p>
            Standards of Care for Transgender Healthcare [mental health &
            medical]
          </p>
          <a href="https://wpath.org/" class="kiwi-link">Visit Website!</a>
        </div>
      </div>
    </div>
  </section>

  <section class="affiliate-section">
    <div class="section-heading affiliate-heading">
      <h2>Featured Partner - Transcend Garments</h2>
      <p>Our trusted partner for high-quality gender affirming gear</p>
    </div>

    <div class="affiliate-card">
      <div class="affiliate-img">
        <img
          src="/images/organisation-logos/transcendgarments.png"
          alt="affiliate Organisation"
        />
      </div>
      <div class="affiliate-body">
        <span class="affiliate-category">Featured Partner</span>
        <h3>Transcend Garments</h3>
        <p>
          Transcend is a small New Zealand-based business, dedicated to creating
          high-quality gender-affirming garments. Each piece is handcrafted in
          small batches to ensure quality and consistency. Transcend is
          passionate about addressing gaps in resources for transgender
          individuals and actively seeks input from the community to develop
          new, accessible products tailored to their needs. As a brand, we aim
          to push the boundaries of what gender-affirming clothing can be.
        </p>
        <a href="https://transcendgarments.com/" class="affiliate-link"
          >Visit Website!</a
        >
      </div>
    </div>
  </section>

