  <section class="video-resources" id="video-resources">
    <div class="section-heading">
      <h2>Video Resources</h2>
      <p>
        Educational videos to support your journey and expand your understanding
      </p>
    </div>

    <div class="video-cards-container">
      <div class="video-card">
        <div class="video-img">
          <img
            src="/images/organisation-logos/insideout-logo-transparent-550.png"
            alt="Video Resource"
          />
        </div>
        <div class="video-body">
          <span class="video-category">Educational Video</span>
          <h3>InsideOUT</h3>
          <p>
            Created by RainbowYOUTH and partners. This resource is curated for
            NZ education, it features a series of short episodes (Episodes 1-5)
            covering everything from "Gender, Sex & sexuality" to "Transgender &
            intersex identities". <br />
            Recommended for: Beginners, Teachers, Family members and youth
          </p>
          <a
            href="https://insideout.ry.org.nz/video-resources"
            class="video-link">Watch Videos!</a
          >
        </div>
      </div>

      <div class="video-card">
        <div class="video-img">
          <img
            src="/images/organisation-logos/healthify.webp"
            alt="Video Resource"
          />
        </div>
        <div class="video-body">
          <span class="video-category">Educational Video</span>
          <h3>Healthify Gender Diversity</h3>
          <p>
            This health portal hosts several short and practical videos
            including "What it's like to be intersex" and other personal stories
            like "Charly Walsh's Transgender Story". <br />
            Recommended for: A clinical yet empathetic overview of what gender dysphoria
            feels like and how it is treated in NZ.
          </p>
          <a
            href="https://healthify.nz/health-a-z/g/gender-diversity"
            class="video-link">Watch Videos!</a
          >
        </div>
      </div>
    </div>

    <!-- YouTube Embeds Section -->
    <div class="youtube-embeds-section">
      <div class="subsection-title">
        <h3>Featured Videos</h3>
      </div>

      <div class="youtube-embed-card">
        <div class="embed-container">
          <iframe
            width="560"
            height="315"
            src="https://www.youtube-nocookie.com/embed?listType=playlist&list=PL4lyxUW1_5XPUDoDD6HGWNZWYhe8O_FXA"
            title="YouTube video player"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
          >
          </iframe>
        </div>
        <div class="embed-info">
          <span class="video-badge">Video Series</span>
          <h4>Te Ao Takat&#257;pui</h4>
          <p>
            A beautiful documentary series by InsideOUT K&#333;aro that shares
            the stories of Takat&#257;pui (M&#257;ori Rainbow) community
            members.
          </p>
          <p class="video-meta">
            <i class="fas fa-info-circle"></i>
            Recommended for: Understanding the intersection of culture, indigeneity,
            and gender identity in Aotearoa.
          </p>
        </div>
      </div>
    </div>
  </section>
