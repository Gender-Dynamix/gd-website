            alt="Kiwi Organisation"
          />
        </div>
        <div class="kiwi-body">
          <span class="kiwi-category"
            >Gender Diverse Informational Organisation</span
          >
          <h3>Counting Ourselves</h3>
          <p>
            Counting Ourselves is an anonymous health survey designed by and for
            trans and non-binary people living in Aotearoa New Zealand.
          </p>
          <a href="https://countingourselves.nz/" class="kiwi-link"
            >Visit Website!</a
